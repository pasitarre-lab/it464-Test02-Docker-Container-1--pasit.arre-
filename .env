# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME= it464-test02-pasit

MY_USERNAME= pasit #ใส่ชื่อผู้ใช้ของคุณ
HTTP_PORT= pasithttp # พอร์ตที่ใช้สำหรับบริการต่าง ๆ

# พอร์ตสำหรับ Web Proxy (Nginx)

 PMA_PORT= pasitpma # พอร์ตสำหรับ phpMyAdmin

DB_NAME= pasitdb # DB Details
DB_USER=root
